"$schema" = 'https://starship.rs/config-schema.json'

add_newline = true

format = """
[¯éÂ](surface0)\
$os\
$username\
[¯é░](bg:peach fg:surface0)\
$directory\
[¯é░](fg:peach bg:green)\
$git_branch\
$git_status\
[¯é░](fg:green bg:teal)\
$c\
$rust\
$golang\
$nodejs\
$php\
$java\
$kotlin\
$haskell\
$python\
[¯é░](fg:teal bg:blue)\
$docker_context\
[¯é░](fg:blue bg:purple)\
$time\
[¯é┤ ](fg:purple)\
$line_break$character"""

palette = 'rose-pine'

